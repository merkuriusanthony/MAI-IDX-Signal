# Telegram delivery
TELEGRAM_BOT_TOKEN=123456:your-telegram-bot-token
TELEGRAM_CHAT_ID=-1000000000000

# WhatsApp bridge
WHATSAPP_ENABLED=false

# Database (async SQLite)
DATABASE_URL=sqlite+aiosqlite:///./data/signals.db

# Stockbit authenticated session
STOCKBIT_SESSION_COOKIE=

# Data
IDX_UNIVERSE_PATH=/opt/data/idx_universe.txt

# Claude / Anthropic-compatible endpoint (e.g. 9Router)
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_AUTH_TOKEN=your-anthropic-or-9router-token
CLAUDE_MODEL=claude-opus-4-8

# Ops
LOG_LEVEL=INFO
