# Telegram delivery
# Get token from @BotFather — never commit the real token
TELEGRAM_BOT_TOKEN=123456:your-telegram-bot-token
TELEGRAM_CHAT_ID=
TELEGRAM_GROUP_ID=-1004352444069

# WhatsApp bridge (optional)
WHATSAPP_ENABLED=false
# WHATSAPP_BRIDGE_URL=http://your-wa-bridge/send

# Database (async SQLite — path relative to app working dir)
DATABASE_URL=sqlite+aiosqlite:///./data/signals.db

# Data sources
STOCKBIT_SESSION_COOKIE=

# IDX universe file (655 symbols if file present; else repo fallback)
IDX_UNIVERSE_PATH=/opt/data/idx_universe.txt

# Chart output directory
CHART_DIR=./data/charts

# Scanner tuning
SCAN_CONCURRENCY=24
SCAN_TOP_N=5
SCAN_MIN_AVG_VALUE=1000000000
SCAN_MIN_HISTORY_DAYS=60
SCAN_DEV_LIMIT=0
# Per-symbol fetch timeout (seconds); a hung yfinance call is abandoned.
SCAN_FETCH_TIMEOUT=25
# Per-worker inter-fetch throttle in ms (0=off) — rate-limit safety for ~800 symbols.
SCAN_THROTTLE_MS=0
# Persist live scan progress every N symbols (crash-recoverable checkpoint).
SCAN_CHECKPOINT_INTERVAL=25

# Universe auto-update (daily IPO/delisting sync at 07:50 WIB)
UNIVERSE_AUTOUPDATE_ENABLED=true
# Abort update if fetched list < this fraction of current size (safety gate).
UNIVERSE_MIN_RATIO=0.80
# Optional overrides (default: alongside the universe file):
# UNIVERSE_BACKUP_DIR=/opt/data/universe_backups
# UNIVERSE_CHANGES_LOG=/opt/data/universe_changes.jsonl
# Data source URLs (override only if upstream endpoints change):
# IDX_LISTED_URL=https://www.idx.co.id/primary/StockData/GetSecuritiesStock?start=0&length=9999&code=&sector=&board=&language=en-us
# STOCKBIT_UNIVERSE_URL=https://exodus.stockbit.com/findata-view/company/list

# Claude / Anthropic-compatible endpoint
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_AUTH_TOKEN=your-anthropic-or-9router-token
CLAUDE_MODEL=claude-sonnet-4-6

# Cloudflare (for tunnel + DNS management)
CF_API_TOKEN=cfut_your-token-here
CF_ACCOUNT_ID=ab9e7769a6fe4a9c5a0a73cf20158dd9
CF_ZONE_ID=96ce9ec8172ae6f89bf977045bd0fed1

# Ops
LOG_LEVEL=INFO
