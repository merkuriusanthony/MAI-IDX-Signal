# Telegram delivery
# Get token from @BotFather — never commit the real token
TELEGRAM_BOT_TOKEN=123456:your-telegram-bot-token
TELEGRAM_CHAT_ID=
TELEGRAM_GROUP_ID=-1004352444069

# WhatsApp bridge (optional)
WHATSAPP_ENABLED=false
# WHATSAPP_BRIDGE_URL=http://your-wa-bridge/send

# Database (async SQLite — path relative to app working dir)
DATABASE_URL=sqlite+aiosqlite:///./data/signals.db

# Data sources
STOCKBIT_SESSION_COOKIE=

# IDX universe file (655 symbols if file present; else repo fallback)
IDX_UNIVERSE_PATH=/opt/data/idx_universe.txt

# Chart output directory
CHART_DIR=./data/charts

# Scanner tuning
SCAN_CONCURRENCY=8
SCAN_TOP_N=5
SCAN_MIN_AVG_VALUE=1000000000
SCAN_MIN_HISTORY_DAYS=60
SCAN_DEV_LIMIT=0

# Claude / Anthropic-compatible endpoint
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_AUTH_TOKEN=your-anthropic-or-9router-token
CLAUDE_MODEL=claude-sonnet-4-6

# Ops
LOG_LEVEL=INFO
